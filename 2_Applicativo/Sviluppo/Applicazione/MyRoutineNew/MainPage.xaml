<?xml version="1.0" encoding="utf-8" ?>
<!--
    MainPage.xaml  –  Schermata Home
    
    Proprietà C# usate:
      MainCS.Nome        → Label x:Name="LabelBenvenuto"
      MainCS.Cognome     → Label x:Name="LabelBenvenuto"
      Attivita.Nome      → Label in ogni TaskCard
      Attivita.Descrizione
      Attivita.DateTimeInizio / DateTimeFine  → orario range
      Attivita.Categoria
    
    Nel code-behind (MainPage.xaml.cs) impostare:
      LabelBenvenuto.Text   = $"Bentornato, {MainCS.Nome}!";
      ProgressOggi.Progress = taskCompletate / taskTotali;
      LabelProgressTesto.Text = $"{completate} / {totali} completate";
      // Popolare le 3 card task e aggiungere stile "Corrente"
      // sulla card dell'attività nell'orario attuale.
-->
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MyRoutineNew.MainPage"
    BackgroundColor="{StaticResource BgPage}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ════════════════════════════════
                 HEADER  –  Avatar + saluto
            ════════════════════════════════ -->
            <Grid
                Padding="20,48,20,16"
                ColumnDefinitions="56,*,40"
                ColumnSpacing="14">

                <!-- Avatar (tappabile → Profilo) -->
                <Border
                    Grid.Column="0"
                    WidthRequest="52"
                    HeightRequest="52"
                    BackgroundColor="{StaticResource Accent}"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                    </Border.GestureRecognizers>
                    <!-- Iniziali utente: impostare da code-behind su x:Name="LabelAvatarIni" -->
                    <Label
                        x:Name="LabelAvatarIni"
                        Text="MR"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

                <!-- Saluto -->
                <VerticalStackLayout
                    Grid.Column="1"
                    VerticalOptions="Center"
                    Spacing="2">
                    <Label
                        Text="Bentornato 👋"
                        FontSize="12"
                        TextColor="{StaticResource TextSecondary}"/>
                    <!-- Testo impostato da code-behind: LabelBenvenuto.Text -->
                    <Label
                        x:Name="LabelBenvenuto"
                        Text="Marco Rossi"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}"/>
                </VerticalStackLayout>

                <!-- Pulsante notifiche (placeholder) -->
                <Border
                    Grid.Column="2"
                    WidthRequest="36"
                    HeightRequest="36"
                    BackgroundColor="{StaticResource BgMuted}"
                    StrokeThickness="0"
                    VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Label
                        Text="🔔"
                        FontSize="16"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>
                </Border>

            </Grid>

            <!-- ════════════════════════════════
                 CARD AVANZAMENTO GIORNALIERO
            ════════════════════════════════ -->
            <Border
                Margin="20,0,20,20"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1"
                Padding="18,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <!-- Titolo + contatore -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Text="Completamento oggi"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}"/>
                        <!-- Impostare da code-behind: LabelProgressTesto.Text -->
                        <Label
                            x:Name="LabelProgressTesto"
                            Grid.Column="1"
                            Text="2 / 5"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}"/>
                    </Grid>

                    <!-- Barra di avanzamento
                         Impostare da code-behind: ProgressOggi.Progress = 0.4 -->
                    <ProgressBar
                        x:Name="ProgressOggi"
                        Progress="0.4"
                        ProgressColor="{StaticResource Accent}"
                        BackgroundColor="{StaticResource ProgressBg}"
                        HeightRequest="8"/>

                    <!-- Sotto-testo -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Text="40% completato"
                            FontSize="11"
                            TextColor="{StaticResource TextMuted}"/>
                        <Label
                            Grid.Column="1"
                            Text="3 rimanenti"
                            FontSize="11"
                            TextColor="{StaticResource TextMuted}"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════
                 TITOLO SEZIONE TASK
            ════════════════════════════════ -->
            <Label
                Margin="20,0,20,12"
                Text="PROSSIME TASK"
                FontSize="11"
                FontAttributes="Bold"
                CharacterSpacing="1.5"
                TextColor="{StaticResource TextSecondary}"/>

            <!-- ════════════════════════════════
                 TASK 1  –  Completata
                 Attivita: Nome / Categoria / DateTimeInizio
            ════════════════════════════════ -->
            <Border
                x:Name="CardTask1"
                Margin="20,0,20,10"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1"
                Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="16,*,Auto" ColumnSpacing="12">

                    <!-- Dot stato -->
                    <Ellipse
                        Grid.Column="0"
                        WidthRequest="10"
                        HeightRequest="10"
                        Fill="{StaticResource AccentGreen}"
                        VerticalOptions="Center"/>

                    <!-- Info task -->
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <!-- Impostare da code-behind: LabelTask1Nome.Text = attivita.Nome -->
                        <Label
                            x:Name="LabelTask1Nome"
                            Text="Meditazione mattutina"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}"/>
                        <!-- Impostare: LabelTask1Cat.Text = attivita.Categoria -->
                        <Label
                            x:Name="LabelTask1Cat"
                            Text="Benessere"
                            FontSize="11"
                            TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>

                    <!-- Orario / stato -->
                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                        <!-- Impostare: LabelTask1Ora.Text = attivita.DateTimeInizio.ToString("HH:mm") -->
                        <Label
                            x:Name="LabelTask1Ora"
                            Text="07:00"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextMuted}"
                            HorizontalTextAlignment="End"/>
                        <Label
                            Text="✓ fatto"
                            FontSize="9"
                            TextColor="{StaticResource AccentGreen}"
                            FontAttributes="Bold"
                            HorizontalTextAlignment="End"/>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- ════════════════════════════════
                 TASK 2  –  CORRENTE (evidenziata)
                 BackgroundColor e bordo arancio
            ════════════════════════════════ -->
            <Border
                x:Name="CardTask2"
                Margin="20,0,20,10"
                BackgroundColor="{StaticResource AccentSoft}"
                Stroke="{StaticResource Accent}"
                StrokeThickness="1.5"
                Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="16,*,Auto" ColumnSpacing="12">

                    <!-- Dot arancio con alone -->
                    <Ellipse
                        Grid.Column="0"
                        WidthRequest="10"
                        HeightRequest="10"
                        Fill="{StaticResource Accent}"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label
                            x:Name="LabelTask2Nome"
                            Text="Palestra"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Accent}"/>
                        <Label
                            x:Name="LabelTask2Cat"
                            Text="Fitness"
                            FontSize="11"
                            TextColor="{StaticResource TextSecondary}"/>
                        <!-- Badge "ORA" -->
                        <Border
                            BackgroundColor="{StaticResource Accent}"
                            StrokeThickness="0"
                            Padding="6,2"
                            HorizontalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6"/>
                            </Border.StrokeShape>
                            <Label
                                Text="ORA"
                                FontSize="9"
                                FontAttributes="Bold"
                                TextColor="White"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                        <Label
                            x:Name="LabelTask2Ora"
                            Text="10:00"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="{StaticResource Accent}"
                            HorizontalTextAlignment="End"/>
                        <Label
                            x:Name="LabelTask2OraFine"
                            Text="– 10:45"
                            FontSize="9"
                            TextColor="{StaticResource TextMuted}"
                            HorizontalTextAlignment="End"/>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- ════════════════════════════════
                 TASK 3  –  Futura
            ════════════════════════════════ -->
            <Border
                x:Name="CardTask3"
                Margin="20,0,20,10"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1"
                Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="16,*,Auto" ColumnSpacing="12">

                    <Ellipse
                        Grid.Column="0"
                        WidthRequest="10"
                        HeightRequest="10"
                        Fill="{StaticResource BgMuted}"
                        Stroke="{StaticResource BorderBrush}"
                        StrokeThickness="2"
                        VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label
                            x:Name="LabelTask3Nome"
                            Text="Studio Italiano"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}"/>
                        <Label
                            x:Name="LabelTask3Cat"
                            Text="Apprendimento"
                            FontSize="11"
                            TextColor="{StaticResource TextSecondary}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End" Spacing="2">
                        <Label
                            x:Name="LabelTask3Ora"
                            Text="14:30"
                            FontSize="11"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextMuted}"
                            HorizontalTextAlignment="End"/>
                        <Label
                            x:Name="LabelTask3OraFine"
                            Text="– 15:00"
                            FontSize="9"
                            TextColor="{StaticResource TextMuted}"
                            HorizontalTextAlignment="End"/>
                    </VerticalStackLayout>

                </Grid>
            </Border>

            <!-- Spazio fondo per la tab bar -->
            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
