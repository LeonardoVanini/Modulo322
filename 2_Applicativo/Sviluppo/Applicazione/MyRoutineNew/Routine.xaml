<?xml version="1.0" encoding="utf-8" ?>
<!--
    Routine.xaml  –  Schermata Agenda

    Proprietà C# usate:
      Attivita.Nome
      Attivita.Descrizione
      Attivita.DateTimeInizio  → ora inizio card
      Attivita.DateTimeFine    → ora fine card
      Attivita.Categoria       → strip colore laterale

    Espansione day-card: gestita da code-behind tramite i metodi
      OnDay1Tapped, OnDay2Tapped, OnDay3Tapped (TapGestureRecognizer)
    che fanno toggle di:
      TasksDay1.IsVisible, TasksDay2.IsVisible, TasksDay3.IsVisible

    Bottone "Aggiungi task" → OnAggiungiTapped nel code-behind
    che aprirà un DisplayPrompt o una pagina modale di inserimento.
-->
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MyRoutineNew.Routine"
    BackgroundColor="{StaticResource BgPage}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ════════════════════════════════
                 HEADER
            ════════════════════════════════ -->
            <VerticalStackLayout Padding="20,48,20,16" Spacing="4">
                <Label
                    Text="Agenda"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextPrimary}"/>
                <Label
                    x:Name="LabelMeseCorrente"
                    Text="Aprile 2025"
                    FontSize="12"
                    TextColor="{StaticResource TextSecondary}"/>
            </VerticalStackLayout>

            <!-- ════════════════════════════════
                 GIORNO 1  –  Oggi (espanso di default)
            ════════════════════════════════ -->
            <Border
                Margin="16,0,16,10"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource Accent}"
                StrokeThickness="1.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout>

                    <!-- Header giorno (tappabile) -->
                    <Grid
                        Padding="16,14"
                        ColumnDefinitions="48,*,Auto,24"
                        ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDay1Tapped"/>
                        </Grid.GestureRecognizers>

                        <!-- Numero giorno evidenziato (oggi) -->
                        <Border
                            Grid.Column="0"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{StaticResource Accent}"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label
                                x:Name="LabelDay1Num"
                                Text="24"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Border>

                        <!-- Info giorno -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label
                                x:Name="LabelDay1Nome"
                                Text="Giovedì · Oggi"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextPrimary}"/>
                            <Label
                                x:Name="LabelDay1Subtxt"
                                Text="5 task programmate"
                                FontSize="10"
                                TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>

                        <!-- Pill contatore task -->
                        <Border
                            Grid.Column="2"
                            BackgroundColor="{StaticResource BgMuted}"
                            StrokeThickness="0"
                            Padding="8,3"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="99"/>
                            </Border.StrokeShape>
                            <Label
                                x:Name="LabelDay1Count"
                                Text="5"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextSecondary}"/>
                        </Border>

                        <!-- Chevron -->
                        <Label
                            Grid.Column="3"
                            x:Name="ChevronDay1"
                            Text="▾"
                            FontSize="14"
                            TextColor="{StaticResource TextMuted}"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"/>
                    </Grid>

                    <!-- Separatore -->
                    <BoxView HeightRequest="1" BackgroundColor="{StaticResource BorderColor}"/>

                    <!-- ── Lista task del giorno 1 ──
                         Toggle IsVisible da code-behind: TasksDay1.IsVisible
                         Popolare con oggetti Attivita -->
                    <VerticalStackLayout
                        x:Name="TasksDay1"
                        Padding="16,10,16,14"
                        Spacing="8"
                        IsVisible="True">

                        <!-- Task singola: ripetere per ogni Attivita del giorno -->
                        <Grid
                            ColumnDefinitions="4,*,Auto"
                            ColumnSpacing="10"
                            Padding="12,10"
                            BackgroundColor="{StaticResource BgSurface}">
                            <!-- Usare Border invece di Grid se si vuole CornerRadius -->
                            <BoxView
                                Grid.Column="0"
                                WidthRequest="4"
                                HeightRequest="36"
                                BackgroundColor="{StaticResource AccentGreen}"
                                VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label
                                    Text="Meditazione"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}"/>
                                <Label
                                    Text="Benessere mentale"
                                    FontSize="10"
                                    TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                Text="07:00"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextMuted}"
                                VerticalOptions="Center"/>
                        </Grid>

                        <Grid
                            ColumnDefinitions="4,*,Auto"
                            ColumnSpacing="10"
                            Padding="12,10"
                            BackgroundColor="{StaticResource BgSurface}">
                            <BoxView
                                Grid.Column="0"
                                WidthRequest="4"
                                HeightRequest="36"
                                BackgroundColor="{StaticResource Accent}"
                                VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label
                                    Text="Palestra"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}"/>
                                <Label
                                    Text="Fitness"
                                    FontSize="10"
                                    TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                Text="10:00"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextMuted}"
                                VerticalOptions="Center"/>
                        </Grid>

                        <Grid
                            ColumnDefinitions="4,*,Auto"
                            ColumnSpacing="10"
                            Padding="12,10"
                            BackgroundColor="{StaticResource BgSurface}">
                            <BoxView
                                Grid.Column="0"
                                WidthRequest="4"
                                HeightRequest="36"
                                BackgroundColor="{StaticResource AccentGreen}"
                                VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label
                                    Text="Studio Italiano"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}"/>
                                <Label
                                    Text="30 minuti"
                                    FontSize="10"
                                    TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label
                                Grid.Column="2"
                                Text="14:30"
                                FontSize="10"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextMuted}"
                                VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════
                 GIORNO 2  –  Chiuso
            ════════════════════════════════ -->
            <Border
                Margin="16,0,16,10"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Grid
                        Padding="16,14"
                        ColumnDefinitions="48,*,Auto,24"
                        ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDay2Tapped"/>
                        </Grid.GestureRecognizers>

                        <Border
                            Grid.Column="0"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{StaticResource BgMuted}"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label
                                Text="25"
                                FontSize="15"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextPrimary}"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label
                                Text="Venerdì"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="{StaticResource TextPrimary}"/>
                            <Label
                                Text="3 task programmate"
                                FontSize="10"
                                TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>

                        <Border
                            Grid.Column="2"
                            BackgroundColor="{StaticResource BgMuted}"
                            StrokeThickness="0"
                            Padding="8,3"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="99"/>
                            </Border.StrokeShape>
                            <Label Text="3" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}"/>
                        </Border>

                        <Label
                            Grid.Column="3"
                            x:Name="ChevronDay2"
                            Text="▸"
                            FontSize="14"
                            TextColor="{StaticResource TextMuted}"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"/>
                    </Grid>

                    <BoxView
                        x:Name="SepDay2"
                        HeightRequest="1"
                        BackgroundColor="{StaticResource BorderColor}"
                        IsVisible="False"/>

                    <!-- Task giorno 2: popolate da code-behind -->
                    <VerticalStackLayout
                        x:Name="TasksDay2"
                        Padding="16,10,16,14"
                        Spacing="8"
                        IsVisible="False">
                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="10" Padding="12,10" BackgroundColor="{StaticResource BgSurface}">
                            <BoxView Grid.Column="0" WidthRequest="4" HeightRequest="36" BackgroundColor="{StaticResource AccentRed}" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Corsa mattutina" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="Fitness" FontSize="10" TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="07:30" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                        </Grid>
                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="10" Padding="12,10" BackgroundColor="{StaticResource BgSurface}">
                            <BoxView Grid.Column="0" WidthRequest="4" HeightRequest="36" BackgroundColor="{StaticResource AccentGreen}" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Lettura" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="30 minuti" FontSize="10" TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="21:00" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════
                 GIORNO 3  –  Chiuso
            ════════════════════════════════ -->
            <Border
                Margin="16,0,16,10"
                BackgroundColor="{StaticResource BgCard}"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <VerticalStackLayout>
                    <Grid
                        Padding="16,14"
                        ColumnDefinitions="48,*,Auto,24"
                        ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDay3Tapped"/>
                        </Grid.GestureRecognizers>

                        <Border
                            Grid.Column="0"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="{StaticResource BgMuted}"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="26" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Sabato" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                            <Label Text="2 task programmate" FontSize="10" TextColor="{StaticResource TextSecondary}"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2" BackgroundColor="{StaticResource BgMuted}" StrokeThickness="0" Padding="8,3" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="99"/></Border.StrokeShape>
                            <Label Text="2" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}"/>
                        </Border>

                        <Label Grid.Column="3" x:Name="ChevronDay3" Text="▸" FontSize="14" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    </Grid>

                    <BoxView x:Name="SepDay3" HeightRequest="1" BackgroundColor="{StaticResource BorderColor}" IsVisible="False"/>

                    <VerticalStackLayout x:Name="TasksDay3" Padding="16,10,16,14" Spacing="8" IsVisible="False">
                        <Grid ColumnDefinitions="4,*,Auto" ColumnSpacing="10" Padding="12,10" BackgroundColor="{StaticResource BgSurface}">
                            <BoxView Grid.Column="0" WidthRequest="4" HeightRequest="36" BackgroundColor="{StaticResource Accent}" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Yoga" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"/>
                                <Label Text="45 minuti" FontSize="10" TextColor="{StaticResource TextSecondary}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="09:00" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource TextMuted}" VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ════════════════════════════════
                 PULSANTE  –  Aggiungi task
                 → OnAggiungiTapped nel code-behind
                   crea un nuovo oggetto Attivita e
                   chiede Nome, Descrizione, orario
            ════════════════════════════════ -->
            <Border
                Margin="16,0,16,10"
                BackgroundColor="Transparent"
                Stroke="{StaticResource BorderBrush}"
                StrokeThickness="1.5"
                Padding="16,14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAggiungiTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="8">
                    <Label
                        Text="+"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextMuted}"
                        VerticalOptions="Center"/>
                    <Label
                        Text="Aggiungi task"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextMuted}"
                        VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
